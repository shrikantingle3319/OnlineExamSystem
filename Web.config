<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<connectionStrings>
		<add name="OnlineExamDB" connectionString="Data Source=.;Initial Catalog=OnlineExamSystem;Integrated Security=True;" providerName="System.Data.SqlClient" />
	</connectionStrings>
	<appSettings>
		<add key="ValidationSettings:UnobtrusiveValidationMode" value="None" />
		<add key="SmtpEmail" value="Your_Email" />
		<add key="SmtpPassword" value="App_Password" />
	</appSettings>
	<system.web>
		<compilation debug="true" targetFramework="4.8" />
		<httpRuntime targetFramework="4.8" />
		<authentication mode="Forms">
			<forms loginUrl="~/Account/Login.aspx" timeout="30" />
		</authentication>
		<authorization>
			<deny users="?" />
		</authorization>
	</system.web>

	<location path="Styles.css">
		<system.web>
			<authorization>
				<allow users="*" />
			</authorization>
		</system.web>
	</location>

	<location path="Account">
		<system.web>
			<authorization>
				<allow users="*" />
			</authorization>
		</system.web>
	</location>
</configuration>
